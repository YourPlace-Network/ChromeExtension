{
  "manifest_version": 3,
  "name": "YourPlace Extension",
  "version": "1.0",
  "description": "Share tweets and YouTube videos to YourPlace with one click. Adds a YourPlace button to Twitter/X posts and YouTube's share panel.",
  "homepage_url": "https://yourplace.network",
  "icons": {
    "16": "icons/icon16.png",
    "19": "icons/icon19.png",
    "32": "icons/icon32.png",
    "38": "icons/icon38.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    },
    "default_popup": "src/popup/popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["http://localhost:42424/*"],
  "web_accessible_resources": [{
    "resources": ["yourplace-logo.svg"],
    "matches": ["https://twitter.com/*", "https://x.com/*", "https://*.youtube.com/*"]
  }],
  "content_scripts": [
    {
      "matches": ["https://twitter.com/*", "https://x.com/*"],
      "js": ["src/js/twitter-content.js"],
      "css": ["src/css/twitter-style.css"]
    },
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["src/js/youtube-content.js"],
      "css": ["src/css/youtube-style.css"]
    }
  ]
}